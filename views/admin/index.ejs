<%- include('../partials/head', { title: 'Admin Overview — BI Portal' }) %>
<div class="app-layout">
  <%- include('../partials/sidebar', { currentPage: 'admin' }) %>
  <main class="main-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Admin Overview</h1>
        <p class="page-subtitle">Manage users, workspaces, and dashboards</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon stat-icon-purple">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value"><%= stats.users %></span>
          <span class="stat-label">Total Users</span>
        </div>
        <a href="/admin/users" class="stat-link">View all →</a>
      </div>

      <div class="stat-card">
        <div class="stat-icon stat-icon-blue">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value"><%= stats.workspaces %></span>
          <span class="stat-label">Workspaces</span>
        </div>
        <a href="/admin/workspaces" class="stat-link">View all →</a>
      </div>

      <div class="stat-card">
        <div class="stat-icon stat-icon-teal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value"><%= stats.dashboards %></span>
          <span class="stat-label">Dashboards</span>
        </div>
        <a href="/admin/dashboards" class="stat-link">View all →</a>
      </div>

      <div class="stat-card">
        <div class="stat-icon stat-icon-amber">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value"><%= stats.baUsers %></span>
          <span class="stat-label">Business Analysts</span>
        </div>
        <a href="/admin/users" class="stat-link">View all →</a>
      </div>
    </div>

    <div class="section-header">
      <h2 class="section-title">Recent Users</h2>
      <a href="/admin/users/new" class="btn btn-primary btn-sm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add User
      </a>
    </div>

    <div class="table-card">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% recentUsers.forEach(u => { %>
            <tr>
              <td>
                <div class="table-user">
                  <div class="table-avatar"><%= u.first_name.charAt(0) %><%= u.last_name.charAt(0) %></div>
                  <span><%= u.first_name %> <%= u.last_name %></span>
                </div>
              </td>
              <td class="text-muted"><%= u.email %></td>
              <td><span class="badge badge-<%= u.role %>"><%= u.role === 'admin' ? 'Admin' : 'Business Analyst' %></span></td>
              <td class="text-muted"><%= new Date(u.created_at).toLocaleDateString() %></td>
              <td>
                <a href="/admin/users/<%= u.id %>/edit" class="btn btn-ghost btn-xs">Edit</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="quick-actions">
      <h2 class="section-title">Quick Actions</h2>
      <div class="quick-action-grid">
        <a href="/admin/users/new" class="quick-action-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
          </svg>
          <span>Add New User</span>
        </a>
        <a href="/admin/workspaces/new" class="quick-action-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            <line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
          </svg>
          <span>Add Workspace</span>
        </a>
        <a href="/admin/dashboards/new" class="quick-action-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
          <span>Add Dashboard</span>
        </a>
        <a href="/workspaces" class="quick-action-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span>View Workspaces</span>
        </a>
      </div>
    </div>
  </main>
</div>
</body>
</html>
