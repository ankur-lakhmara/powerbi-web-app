<%- include('partials/head', { title: 'Workspaces — BI Portal' }) %>
<div class="app-layout">
  <%- include('partials/sidebar', { currentPage: 'workspaces', pageTitle: 'Workspaces', backUrl: null }) %>
  <main class="main-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Workspaces</h1>
        <p class="page-subtitle">Select a workspace to explore its dashboards</p>
      </div>
      <% if (user.role === 'admin') { %>
        <a href="/admin/workspaces/new" class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Workspace
        </a>
      <% } %>
    </div>

    <% if (workspaces.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3>No workspaces available</h3>
        <p><% if (user.role === 'admin') { %>Create your first workspace to get started.<% } else { %>No workspaces have been assigned to your account. Contact your administrator.<% } %></p>
        <% if (user.role === 'admin') { %>
          <a href="/admin/workspaces/new" class="btn btn-primary">Create Workspace</a>
        <% } %>
      </div>
    <% } else { %>
      <div class="workspace-grid">
        <% workspaces.forEach((ws, i) => { %>
          <a href="/workspace/<%= ws.id %>" class="workspace-card" style="--delay: <%= i * 60 %>ms">
            <div class="workspace-card-icon" style="--hue: <%= (i * 47 + 220) % 360 %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div class="workspace-card-body">
              <h3 class="workspace-card-title"><%= ws.name %></h3>
              <% if (ws.description) { %>
                <p class="workspace-card-desc"><%= ws.description %></p>
              <% } %>
            </div>
            <div class="workspace-card-footer">
              <span class="workspace-stat">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                  <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                <%= ws.dashboard_count %> dashboard<%= ws.dashboard_count !== 1 ? 's' : '' %>
              </span>
              <span class="card-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>
</body>
</html>
