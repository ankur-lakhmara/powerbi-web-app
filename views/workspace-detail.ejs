<%- include('partials/head', { title: workspace.name + ' — BI Portal' }) %>
<div class="app-layout">
  <%- include('partials/sidebar', { currentPage: 'workspaces', pageTitle: workspace.name, backUrl: '/workspaces', backLabel: 'Workspaces' }) %>
  <main class="main-content">
    <div class="page-header">
      <div class="page-header-left">
        <a href="/workspaces" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          Workspaces
        </a>
        <h1 class="page-title"><%= workspace.name %></h1>
        <% if (workspace.description) { %>
          <p class="page-subtitle"><%= workspace.description %></p>
        <% } %>
      </div>
      <% if (user.role === 'admin') { %>
        <a href="/admin/dashboards/new" class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          Add Dashboard
        </a>
      <% } %>
    </div>

    <% if (dashboards.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
        <h3>No dashboards in this workspace</h3>
        <% if (user.role === 'admin') { %>
          <p>Add a dashboard to get started.</p>
          <a href="/admin/dashboards/new" class="btn btn-primary">Add Dashboard</a>
        <% } else { %>
          <p>No dashboards have been added to this workspace yet.</p>
        <% } %>
      </div>
    <% } else { %>
      <div class="dashboard-grid">
        <% dashboards.forEach((dash, i) => { %>
          <a href="/dashboard/<%= dash.id %>" class="dashboard-card" style="--delay: <%= i * 60 %>ms">
            <div class="dashboard-card-preview">
              <svg viewBox="0 0 120 80" fill="none">
                <rect width="120" height="80" fill="#f9fafb" rx="6"/>
                <rect x="8" y="8" width="50" height="28" rx="3" fill="#ede9fe"/>
                <rect x="62" y="8" width="50" height="28" rx="3" fill="#eff6ff"/>
                <rect x="8" y="44" width="104" height="28" rx="3" fill="#f3f4f6"/>
                <rect x="14" y="50" width="18" height="16" rx="2" fill="#7c3aed" opacity="0.35"/>
                <rect x="38" y="53" width="14" height="13" rx="2" fill="#7c3aed" opacity="0.55"/>
                <rect x="58" y="48" width="13" height="18" rx="2" fill="#7c3aed" opacity="0.75"/>
                <rect x="77" y="52" width="12" height="14" rx="2" fill="#2563eb" opacity="0.55"/>
                <rect x="95" y="46" width="11" height="20" rx="2" fill="#2563eb" opacity="0.35"/>
              </svg>
            </div>
            <div class="dashboard-card-body">
              <h3 class="dashboard-card-title"><%= dash.name %></h3>
              <% if (dash.description) { %>
                <p class="dashboard-card-desc"><%= dash.description %></p>
              <% } %>
              <div class="dashboard-card-meta">
                <span class="meta-tag">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/>
                  </svg>
                  Power BI Report
                </span>
                <span class="card-arrow">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
</div>
</body>
</html>
